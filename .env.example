PORT=3000

# Public website / browser demo
PUBLIC_BASE_URL=https://www.zitoai.xyz

# OKX.AI ASP / A2MCP API base
ASP_BASE_URL=https://asp.zitoai.xyz

# OKX Onchain OS Payment / x402 seller config
# Required only when we intentionally enable paid ASP endpoint calls.
OKX_PAYMENT_ENABLED=false
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=
PAY_TO_ADDRESS=
OKX_BASE_URL=https://web3.okx.com
OKX_PAYMENT_NETWORK=eip155:196
OKX_PAYMENT_PRICE_USD=$0.02
OKX_PAYMENT_SYNC_SETTLE=false

# OpenRouter brain
OPENROUTER_API_KEY=
OPENROUTER_FAST_MODEL=google/gemini-2.5-flash-lite
OPENROUTER_SMART_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://www.zitoai.xyz
OPENROUTER_APP_NAME=ZitoAI
OPENROUTER_MAX_CALLS_PER_MINUTE=20
OPENROUTER_MAX_INPUT_CHARS=12000

# Supabase persistence and private evidence storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=license-evidence

# OAuth security for provider account connections
# Use the ASP/backend host because provider callbacks hit server routes like /auth/freesound/callback.
OAUTH_CALLBACK_BASE_URL=https://asp.zitoai.xyz
OAUTH_STATE_SECRET=
OAUTH_TOKEN_ENCRYPTION_KEY=

# Shutterstock image licensing
SHUTTERSTOCK_CLIENT_ID=
SHUTTERSTOCK_CLIENT_SECRET=
SHUTTERSTOCK_ACCESS_TOKEN=
SHUTTERSTOCK_API_BASE=https://api.shutterstock.com/v2
# Use https://api-sandbox.shutterstock.com/v2 for safe licensing tests.
SHUTTERSTOCK_AUTHORIZE_URL=https://api.shutterstock.com/v2/oauth/authorize
SHUTTERSTOCK_TOKEN_URL=https://api.shutterstock.com/v2/oauth/access_token
SHUTTERSTOCK_SCOPES=licenses.create licenses.view purchases.view

# Freesound sound effects and ambience
# Search/previews use the API token; OAuth is only needed for uploads/bookmarks/other user actions.
FREESOUND_API_KEY=
FREESOUND_CLIENT_ID=
FREESOUND_CLIENT_SECRET=

# Jamendo music tracks
JAMENDO_CLIENT_ID=
