PORT=3000
PUBLIC_BASE_URL=https://www.zitoai.xyz

# Optional. The MVP works without OpenRouter.
OPENROUTER_API_KEY=
OPENROUTER_FAST_MODEL=openai/gpt-4o-mini
OPENROUTER_SMART_MODEL=google/gemini-2.5-flash
OPENROUTER_SITE_URL=https://www.zitoai.xyz
OPENROUTER_APP_NAME=ZitoAI

# Supabase persistence and private evidence storage.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=license-evidence

# Provider OAuth. Generate strong random values for both secrets.
OAUTH_CALLBACK_BASE_URL=https://www.zitoai.xyz
OAUTH_STATE_SECRET=
OAUTH_TOKEN_ENCRYPTION_KEY=

# Provider base URLs are configurable for testing.
OPENVERSE_BASE_URL=https://api.openverse.org/v1
WIKIMEDIA_API_URL=https://commons.wikimedia.org/w/api.php
FREETOUSE_BASE_URL=https://api.freetouse.com/v3
STOCKFILM_BASE_URL=https://api.stockfilm.com/x402

# Authenticated provider credentials (add only after provider approval).
ADOBE_STOCK_API_KEY=
ADOBE_STOCK_CLIENT_ID=
ADOBE_STOCK_CLIENT_SECRET=
ADOBE_STOCK_ACCESS_TOKEN=
MOTION_ELEMENTS_API_SECRET=
SHUTTERSTOCK_CLIENT_ID=
SHUTTERSTOCK_CLIENT_SECRET=
SHUTTERSTOCK_ACCESS_TOKEN=
FREESOUND_API_KEY=
FREESOUND_CLIENT_ID=
FREESOUND_CLIENT_SECRET=
JAMENDO_CLIENT_ID=
EPIDEMIC_SOUND_API_KEY=
SOUNDSTRIPE_API_KEY=

# Set these only from current Shutterstock app documentation.
SHUTTERSTOCK_AUTHORIZE_URL=https://api.shutterstock.com/v2/oauth/authorize
SHUTTERSTOCK_TOKEN_URL=https://api.shutterstock.com/v2/oauth/access_token
SHUTTERSTOCK_SCOPES=licenses.create licenses.view purchases.view
